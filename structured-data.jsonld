      "mainEntity": [
        {
          "@type": "Question",
          "name": "Gdzie znajduje się Restauracja Emilio w Szczecinie?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Restauracja Emilio znajduje się przy ul. Jana Pawła II 43, 70-415 Szczecin. To centrum miasta, łatwo dostępne komunikacją miejską i samochodem."
          }
        },
        {
          "@type": "Question",
          "name": "Jakie są godziny otwarcia Restauracji Emilio?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Restauracja Emilio jest otwarta: poniedziałek–czwartek 13:00–22:00, piątek–sobota 13:00–23:00, niedziela 13:00–20:00."
          }
        },
        {
          "@type": "Question",
          "name": "Czy Restauracja Emilio oferuje catering w Szczecinie?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Tak, Restauracja Emilio oferuje profesjonalny catering włoski na terenie Szczecina. Obsługujemy wesela, imprezy firmowe, urodziny i rocznice. Menu jest indywidualnie komponowane. Kontakt: 508 224 177."
          }
        },
        {
          "@type": "Question",
          "name": "Czy można zarezerwować stolik w Restauracji Emilio?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Tak, rezerwacje przyjmujemy telefonicznie pod numerem +48 508 224 177 lub mailowo: restauracjaemilio@gmail.com."
          }
        },
        {
          "@type": "Question",
          "name": "Czym jest Casa di Emilio?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Casa di Emilio to elegancka sala eventowa w Szczecinie na do 60 osób. Idealna na wesela, urodziny, konferencje i spotkania firmowe. Cena od 150 PLN za osobę, obejmuje catering i obsługę kelnerską."
          }
        },
        {
          "@type": "Question",
          "name": "Gdzie znajduje się Bistro by Emilio?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Bistro by Emilio mieści się w Morskim Centrum Nauki przy ul. Nad Duńczycą 1 w Szczecinie. Oferujemy włoskie lunche, kawy i desery z widokiem na Odrę."
          }
        }
      ]
